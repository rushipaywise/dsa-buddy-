{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "AQ.Ab8RN6J4oiGyUsMdLDlfvqN5rJzOT-WQN55Q_xHTj2o2EXqpHw"
      }
    },
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com",
      "enabled": true
    },
    "browser-use": {
      "type": "command",
      "command": "browser-use --mcp",
      "enabled": true
    }
  }
}